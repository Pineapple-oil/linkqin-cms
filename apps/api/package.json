{
  "name": "@linkqin/api",
  "version": "0.1.0",
  "private": true,
  "description": "linkqin-cms 后端服务（NestJS + Fastify）",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@linkqin/shared": "workspace:*",
    "@linkqin/db": "workspace:*",
    "@linkqin/core": "workspace:*",
    "@linkqin/plugin-sdk": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "image-size": "^2.0.2",
    "@nestjs/common": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "fastify": "^4.28.1",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.38.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
