{
  "name": "@linkqin/plugin-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "插件开发 SDK：插件只能依赖本包，不得 import apps/api 或 apps/admin 内部代码",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@linkqin/shared": "workspace:*",
    "zod": "^3.24.1"
  }
}
