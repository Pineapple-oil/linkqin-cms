{
  "name": "@linkqin/core",
  "version": "0.1.0",
  "private": true,
  "description": "CMS 核心领域模型、字段注册表、内容引擎、插件宿主",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@linkqin/shared": "workspace:*",
    "@linkqin/plugin-sdk": "workspace:*",
    "zod": "^3.24.1"
  }
}
