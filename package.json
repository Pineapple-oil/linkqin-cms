{
  "name": "linkqin-cms",
  "version": "0.1.0",
  "private": true,
  "description": "轻量级、插件化、API-first 的 Node.js Headless CMS",
  "license": "MIT",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* --filter=./packages/* run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:e2e": "echo \"E2E tests configured via Playwright (Phase 6)\" && exit 0",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @linkqin/db db:generate",
    "db:migrate": "pnpm --filter @linkqin/db db:migrate",
    "db:seed": "pnpm --filter @linkqin/api seed",
    "clean": "pnpm -r exec rimraf dist node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
